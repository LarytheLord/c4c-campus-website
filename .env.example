# C4C Campus Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# SUPABASE (Required)
# =============================================================================
# Get these from your Supabase project: Settings > API

PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# EMAIL (Required for notifications)
# =============================================================================
# Get your API key from https://resend.com/api-keys

RESEND_API_KEY=re_your_api_key

# =============================================================================
# DATABASE (Local scripts only - NOT needed in Vercel/production)
# =============================================================================
# Only used by local dev scripts: npm run db:validate, db:migrate, db:backup
# Get this from Supabase: Project Settings > Database > Connection string > URI

# DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# =============================================================================
# SITE CONFIGURATION
# =============================================================================

SITE_URL=https://your-domain.com
NODE_ENV=development

# =============================================================================
# OPENROUTER (Optional - for AI features)
# =============================================================================
# Management API key for auto-provisioning student API keys
# Create one at https://openrouter.ai/settings/management-keys

OPENROUTER_MANAGEMENT_KEY=sk-or-v1-...

# Weekly spending limit per student in USD (default: 10)
OPENROUTER_STUDENT_WEEKLY_LIMIT=10

# Hours a student must wait before regenerating their key (default: 24)
OPENROUTER_REGEN_COOLDOWN_HOURS=24

# =============================================================================
# CRON (Optional - for scheduled tasks)
# =============================================================================
# Secret token to authenticate cron job requests (e.g. module unlock notifications)
# Generate a random string: openssl rand -hex 32

CRON_SECRET=your-cron-secret

# =============================================================================
# STRIPE (Optional - for paid features)
# =============================================================================
# Only needed if charging for courses

# PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_...
# PUBLIC_STRIPE_PRICE_PRO_YEARLY=price_...
